NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── File Storage — Vercel Blob (avatars + contracts) ─────────
BLOB_READ_WRITE_TOKEN=

# ─── File Storage — Cloudflare R2 (content submissions) ───────
# Max 500MB per file. Zero egress cost. TUS resumable uploads.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public R2 endpoint (set after enabling public access on bucket)
NEXT_PUBLIC_R2_PUBLIC_URL=

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=
# Must match your verified sending domain in Resend dashboard
EMAIL_FROM=noreply@yourdomain.com

# ─── Background Jobs (Trigger.dev) ───────────────────────────
TRIGGER_SECRET_KEY=
# Project ref from Trigger.dev dashboard
TRIGGER_PROJECT_REF=

# ─── Rate Limiting (Upstash Redis) ───────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000