generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum DealStage {
  BRIEF_RECEIVED
  CREATOR_ASSIGNED
  CONTRACT_SENT
  IN_PRODUCTION
  PENDING_APPROVAL
  LIVE
  PAYMENT_PENDING
  CLOSED
}

enum ContractStatus {
  NOT_SENT
  SENT
  SIGNED
}

enum PaymentStatus {
  PENDING
  RECEIVED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
}

enum BriefStatus {
  NEW
  REVIEWED
  CONVERTED
  DECLINED
}

enum PartnershipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// Creator profile — owned by a Clerk user with role='creator'
model Creator {
  id             String   @id @default(cuid())
  /// Clerk user ID — matches the logged-in user to their profile
  clerkId        String   @unique
  name           String
  /// URL-safe handle e.g. "janedoe". Used in /creators/:handle public URLs.
  handle         String   @unique
  bio            String?
  avatarUrl      String?
  /// e.g. ["instagram", "tiktok", "youtube"]
  platforms      String[]
  /// e.g. ["fashion", "beauty", "fitness"]
  nicheTags      String[]
  followerCount  Int?
  /// Stored as percentage e.g. 4.25 = 4.25%
  engagementRate Decimal? @db.Decimal(5, 2)
  /// Controls visibility on /discover
  isPublic       Boolean  @default(false)
  /// Clerk user ID of the agency this creator is rostered to
  agencyClerkId  String?

  deals               Deal[]
  contentSubmissions  ContentSubmission[]
  partnershipRequests PartnershipRequest[]
  briefTargets        Brief[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublic])
  @@index([nicheTags])
}

/// Brand / advertiser company — inline-created when agency creates a Deal
model Brand {
  id      String  @id @default(cuid())
  name    String
  website String?
  logoUrl String?

  deals Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Core deal entity — owned by an agency user
model Deal {
  id String @id @default(cuid())

  title String

  /// Clerk user ID of the agency account manager who owns this deal
  agencyClerkId String

  brandId   String
  creatorId String?

  stage DealStage @default(BRIEF_RECEIVED)

  /// Deal face value in USD cents stored as Decimal
  dealValue     Decimal @db.Decimal(10, 2)
  /// Commission percentage e.g. 20.00 = 20%
  commissionPct Decimal @db.Decimal(5, 2)
  /// Always calculated: dealValue × (1 − commissionPct / 100). Never user input.
  creatorPayout Decimal @db.Decimal(10, 2)

  deadline DateTime?

  contractStatus ContractStatus @default(NOT_SENT)
  /// Vercel Blob URL for the uploaded contract file
  contractUrl    String?

  paymentStatus PaymentStatus @default(PENDING)

  /// Internal agency notes — never exposed to creator or brand manager
  notes String?

  /// Set when this deal was converted from a Brief
  briefId String? @unique

  brand       Brand               @relation(fields: [brandId], references: [id])
  creator     Creator?            @relation(fields: [creatorId], references: [id])
  brief       Brief?              @relation(fields: [briefId], references: [id])
  submissions ContentSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyClerkId, stage])
  @@index([creatorId])
  @@index([deadline])
}

/// One content submission round from a creator — each resubmission is a new row
model ContentSubmission {
  id String @id @default(cuid())

  dealId    String
  creatorId String

  /// Increments on each resubmission
  round Int @default(1)

  /// URL to the submitted content (YouTube, Google Drive, etc.)
  url String?
  /// Cloudflare R2 object key — set when creator uploads a file directly
  fileKey String?

  status SubmissionStatus @default(PENDING)

  /// Agency feedback text when requesting changes
  feedback String?

  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  creator Creator @relation(fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
}

/// Brief submitted by a brand manager via /briefs/new
model Brief {
  id String @id @default(cuid())

  /// Clerk user ID of the brand manager who submitted
  brandManagerClerkId String
  /// Clerk user ID of the target agency
  agencyClerkId String

  /// Optional: pre-targeted at a specific creator (from /creators/:handle CTA)
  creatorId String?

  title       String
  description String

  /// Suggested budget in USD cents
  budget   Decimal? @db.Decimal(10, 2)
  platform String?
  niche    String?

  status BriefStatus @default(NEW)

  creator Creator? @relation(fields: [creatorId], references: [id])
  /// Populated when the agency converts this brief to a deal
  deal    Deal?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyClerkId, status])
}

/// Agency recruits a creator discovered on /discover
model PartnershipRequest {
  id String @id @default(cuid())

  /// Clerk user ID of the agency sending the request
  agencyClerkId String
  creatorId     String

  message String?

  status PartnershipStatus @default(PENDING)

  creator Creator @relation(fields: [creatorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyClerkId, creatorId])
}
